# Copy this file to .env (or ~/.iagent/.env on the device) and fill in your values.
# Do NOT commit the real .env to git.

TELEGRAM_TOKEN=your-telegram-bot-token-here
OPENAI_API_KEY=sk-...

# Optional: override the data directory (default: ~/.iagent)
# On rootless Dopamine iPad use:
# IAGENT_HOME=/var/jb/var/mobile/iagent
