{
  "_comment": "iAgent runtime config. Copy to ~/.iagent/config.json (or $IAGENT_HOME/config.json) and edit. Secrets (TELEGRAM_TOKEN, OPENAI_API_KEY) live in .env.",

  "openai_model": "gpt-4o",

  "_comment_allowed": "Telegram user IDs allowed to use the bot. Get yours from @userinfobot. Leave [] to allow ALL users — NOT recommended.",
  "allowed_user_ids": [
    123456789
  ],

  "history_window": 20,
  "max_iterations": 10,

  "shell_timeout": 30,
  "_comment_allowlist": "Optional. If set, only these commands may run via the shell tool. Comment out by removing the key to allow all.",
  "shell_allowlist": null,

  "_comment_apt": "Phase 1.3: apt_install tool. Enabled by default with a safe allowlist.",
  "apt_install_enabled": true,
  "apt_install_allowlist": [
    "ca-certificates", "ncurses", "tmux", "openssh", "curl", "wget",
    "ffmpeg", "imagemagick", "nano", "vim",
    "uikittools", "uikittools-extra", "xclip",
    "SimulateTouch", "simulatetouch", "com.luki120.simulatetouch",
    "libactivator", "activator",
    "ch.xxtou.xxtouch"
  ],

  "_comment_heartbeat": "Phase 2.2: interval in seconds between heartbeat ticks (0 = disabled).",
  "heartbeat_interval": 0,

  "_comment_heartbeat_prompt": "Optional: customise the heartbeat self-prompt.",
  "heartbeat_prompt": "",

  "_comment_mcp": "MCP servers to spawn at startup. Each must be a real JSON-RPC stdio server (protocol 2024-11-05). Their tools auto-register prefixed with `<name>_`. iAgent has no built-in MCP server — leave [] unless you have a real one.",
  "mcp_servers": []
}
