# iAgent configuration — copy to ~/.iagent/config.yaml and fill in your values.
# Secrets (TELEGRAM_TOKEN, OPENAI_API_KEY) belong in .env, not here.

openai_model: gpt-4o

# Telegram user IDs allowed to interact with the bot.
# Get your ID by messaging @userinfobot on Telegram.
# Leave empty ([]) to allow ALL users — not recommended for a personal device agent.
allowed_user_ids:
  - 123456789

# ── Paths ──────────────────────────────────────────────────────────────────
# Defaults resolve relative to $IAGENT_HOME (or ~/.iagent on macOS).
# On rootless Dopamine these should be under /var/jb/var/mobile/iagent/.

# data_dir:       /var/jb/var/mobile/iagent
# workspace_root: /var/jb/var/mobile/iagent/workspace
# db_path:        /var/jb/var/mobile/iagent/iagent.db
# log_dir:        /var/jb/var/mobile/iagent/logs

# ── Agent ──────────────────────────────────────────────────────────────────
history_window: 20    # messages kept in context per chat
max_iterations: 10    # max tool-calling rounds per user message

# ── Shell tool ─────────────────────────────────────────────────────────────
shell_timeout: 30     # seconds before a shell command is killed

# Optional allowlist — only these commands may be run via the shell tool.
# Comment out or remove to allow any command (only do this on a trusted device).
# shell_allowlist:
#   - uname
#   - ls
#   - cat
#   - curl
